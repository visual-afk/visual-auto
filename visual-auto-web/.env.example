# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 로그인 아이디 → synthetic email 도메인 (이메일 없이 아이디+비번 로그인용)
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=visual.local

# AI (Anthropic Claude). 없으면 Gemini로 폴백
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# (선택) 초대 링크 베이스 폴백. 보통은 요청 도메인에서 자동으로 잡으므로 비워둬도 됨.
# Vercel에 올리면 프로덕션/프리뷰 도메인이 자동 사용됩니다. 커스텀 도메인 쓰면 그 주소를 넣으세요.
NEXT_PUBLIC_APP_URL=

# (선택) 추천 주제를 구글시트 planned 행에서 가져올 때만 필요
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
