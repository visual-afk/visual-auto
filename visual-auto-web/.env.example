# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 로그인 아이디 → synthetic email 도메인 (이메일 없이 아이디+비번 로그인용)
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=visual.local

# AI = Gemini 하나로만 사용 (유료 결제 연결 필수 — 무료등급은 일일 한도 초과로 막힘)
# Google AI Studio(aistudio.google.com) 또는 GCP에서 결제(Billing) 연결된 프로젝트의 키를 넣으세요.
GEMINI_API_KEY=
# (선택) 모델 고정. 기본 gemini-2.5-flash
GEMINI_MODEL=

# (선택) 지점 주소 → 좌표 자동찾기(지오코딩). 없으면 주소 자동찾기 버튼만 비활성, 수동 입력은 그대로 동작.
# 발급: developers.kakao.com → 애플리케이션 추가 → "REST API 키" 복사 (플랫폼 도메인 등록 불필요, 서버에서만 호출)
KAKAO_REST_API_KEY=

# (선택) 초대 링크 베이스 폴백. 보통은 요청 도메인에서 자동으로 잡으므로 비워둬도 됨.
# Vercel에 올리면 프로덕션/프리뷰 도메인이 자동 사용됩니다. 커스텀 도메인 쓰면 그 주소를 넣으세요.
NEXT_PUBLIC_APP_URL=

# (선택) 추천 주제를 구글시트 planned 행에서 가져올 때만 필요
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
