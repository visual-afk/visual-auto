# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 로그인 아이디 → synthetic email 도메인 (이메일 없이 아이디+비번 로그인용)
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=visual.local

# AI = Gemini 하나로만 사용 (유료 결제 연결 필수 — 무료등급은 일일 한도 초과로 막힘)
# Google AI Studio(aistudio.google.com) 또는 GCP에서 결제(Billing) 연결된 프로젝트의 키를 넣으세요.
GEMINI_API_KEY=
# (선택) 모델 고정. 기본 gemini-2.5-flash
GEMINI_MODEL=

# (선택) 지점 주소 → 좌표 자동찾기(지오코딩). 없으면 주소 자동찾기 버튼만 비활성, 수동 입력은 그대로 동작.
# 발급: developers.kakao.com → 애플리케이션 추가 → "REST API 키" 복사 (플랫폼 도메인 등록 불필요, 서버에서만 호출)
KAKAO_REST_API_KEY=

# (선택) 초대 링크 베이스 폴백. 보통은 요청 도메인에서 자동으로 잡으므로 비워둬도 됨.
# Vercel에 올리면 프로덕션/프리뷰 도메인이 자동 사용됩니다. 커스텀 도메인 쓰면 그 주소를 넣으세요.
NEXT_PUBLIC_APP_URL=

# (선택) 추천 주제를 구글시트 planned 행에서 가져올 때만 필요
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# (선택) 콘텐츠 캘린더 일정 → 구글 캘린더 내보내기. 위 서비스 계정을 대상 캘린더에
# "일정 변경" 권한으로 공유해야 함. 비워두면 내보내기만 조용히 건너뜀.
GOOGLE_CALENDAR_ID=

# 키워드 상위노출 체크 — 네이버 검색 오픈API (developers.naver.com → 애플리케이션 등록 → 검색 API)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 제품 브랜드(누혜·트리필드·아카데미) 매출 구글시트 — 위 서비스 계정에 읽기 공유 필요.
# 성과 대시보드 브랜드 뷰 + 매일 06:30 KST cron(sync-product-sheet)이 사용.
PRODUCT_SHEET_ID=

# (선택) 구글 서치콘솔 — 위 서비스 계정 이메일을 서치콘솔 속성 사용자로 추가해야 함.
# 등록된 속성과 정확히 일치해야 함 (예: sc-domain:visualsalon.imweb.me 또는 https://visualsalon.imweb.me/)
GSC_SITE_URL=

# (선택) Vercel Cron 인증 시크릿 (crawl-handsos / rank-check 공용)
CRON_SECRET=

# (선택) 콘텐츠 일정 기한 경과 알림톡 템플릿 ID (Solapi 콘솔에서 사전 등록·승인 필요)
# 템플릿 변수: #{이름} #{지점} #{주제} #{예정일} #{경과일} — 비워두면 알림만 조용히 건너뜀.
KAKAO_TMPL_PLAN_OVERDUE=
