# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 로그인 아이디 → synthetic email 도메인 (이메일 없이 아이디+비번 로그인용)
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=visual.local

# AI (Anthropic Claude). 없으면 Gemini로 폴백
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# (선택) 초대 링크 베이스 폴백. 보통은 요청 도메인에서 자동으로 잡으므로 비워둬도 됨.
# Vercel에 올리면 프로덕션/프리뷰 도메인이 자동 사용됩니다. 커스텀 도메인 쓰면 그 주소를 넣으세요.
NEXT_PUBLIC_APP_URL=

# (선택) 추천 주제를 구글시트 planned 행에서 가져올 때만 필요
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=

# 카카오 알림톡 (Solapi). 두 키가 없으면 카톡 발송은 자동으로 건너뛰고 '링크 복사'로 폴백됨.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
# (선택) 발신프로필 pfId — 비우면 비주얼살롱 채널 기본값 사용
KAKAO_SENDER_KEY=
# (선택) 알림톡 실패 시 SMS 대체발송용 발신번호(사전 등록된 번호)
KAKAO_SENDER_PHONE=
# (선택) 템플릿 코드 — 비우면 코드 기본값(가입 초대장) 사용. 가입완료 알림은 별도 등록 후 입력.
KAKAO_TMPL_INVITE_SENT=
KAKAO_TMPL_INVITE_ACCEPTED=
# (선택) 출근 알림톡 템플릿 코드 — 등록 후 입력하면 출근 시 점장/본사에 카톡 발송. 비우면 알림만 skip(출근은 정상).
ATTENDANCE_ALIMTALK_TEMPLATE_ID=
